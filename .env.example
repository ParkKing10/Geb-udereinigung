# Öffentliche Basis-URL der Website in Produktion – OHNE Trailing-Slash.
# Wird verwendet für canonical-URLs, sitemap.xml, robots.txt, OpenGraph und JSON-LD.
# Ohne diese Variable schlägt der Produktions-Build bewusst fehl (Fail-Fast),
# damit keine localhost-URLs live gehen.
#
# Bei Umlaut-Domain die Punycode-Form eintragen (z. B. xn--... .de).
NEXT_PUBLIC_APP_URL=https://www.deutsche-gebaeudedienste.de

# ── Admin-Login ────────────────────────────────────────────────
# Passwort für den geschützten /admin-Bereich (Default in Dev: "admin").
ADMIN_PASSWORD=bitte-sicheres-passwort-setzen
# Zufälliger Geheimschlüssel zum Signieren der Session-Cookies.
AUTH_SECRET=bitte-langen-zufallswert-setzen

# ── KI-Kostenschätzung (optional) ──────────────────────────────
# Ohne Key nutzt der Schätzer eine Heuristik. Mit Key echte Anthropic-Vision.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Conversion-Tracking (GA4 + Google Ads, Consent Mode v2) ────
# Ohne IDs läuft das Tracking im Debug-Modus (Events im dataLayer/console, kein Versand).
# GA4-Mess-ID:
NEXT_PUBLIC_GA_ID=
# Google-Ads-Conversion-ID (Format AW-XXXXXXXXXX):
NEXT_PUBLIC_GOOGLE_ADS_ID=
# Conversion-Labels aus Google Ads (Teil nach dem "/", z. B. "AbCdEfg123"):
#   lead    → Conversion-Aktion "Lead-Formulare senden" (Quelle: Website) – DAS ist die aus deinem Screenshot
#   contact → Kontaktformular
#   call    → Klick auf Telefonnummer
NEXT_PUBLIC_ADS_LEAD_LABEL=
NEXT_PUBLIC_ADS_CONTACT_LABEL=
NEXT_PUBLIC_ADS_CALL_LABEL=
